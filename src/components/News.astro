---
import { news } from "../data/news";
---

{
  news.length > 0 && (
    <section id="news" class="mx-auto max-w-3xl px-6 py-16">
      <h2 class="text-xl font-semibold tracking-tight text-zinc-900 md:text-2xl dark:text-zinc-100">
        News
      </h2>
      <ul class="mt-6 space-y-3">
        {news.map((item) => (
          <li class="flex flex-col gap-1 text-sm sm:flex-row sm:items-baseline sm:gap-4">
            <span class="font-mono tabular-nums text-xs text-zinc-500 dark:text-zinc-400 sm:w-20 sm:shrink-0">
              {item.date}
            </span>
            <span class="leading-relaxed text-zinc-700 dark:text-zinc-300">
              {item.text}
            </span>
          </li>
        ))}
      </ul>
    </section>
  )
}

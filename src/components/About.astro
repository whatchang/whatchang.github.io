---
import { profile } from "../data/profile";

const paragraphs = profile.about.split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean);
---

<section id="about" class="mx-auto max-w-3xl px-6 py-16">
  <h2
    class="text-xl font-semibold tracking-tight text-zinc-900 md:text-2xl dark:text-zinc-100"
  >
    About
  </h2>
  <div class="mt-6 max-w-prose space-y-4 leading-relaxed text-zinc-700 dark:text-zinc-300">
    {paragraphs.map((p) => <p>{p}</p>)}
  </div>
</section>

---
import {
  publications,
  SELF_NAMES,
  type Publication,
} from "../data/publications";
import LinkChip from "./LinkChip.astro";

const typeOrder: Publication["type"][] = [
  "journal",
  "conference",
  "workshop",
  "preprint",
];

const typeLabel: Record<Publication["type"], string> = {
  journal: "Journal",
  conference: "Conference",
  workshop: "Workshop",
  preprint: "Preprint",
};

const typeHeadingClass: Record<Publication["type"], string> = {
  journal:
    "border-indigo-500 text-indigo-700 dark:border-indigo-400 dark:text-indigo-300",
  conference:
    "border-emerald-500 text-emerald-700 dark:border-emerald-400 dark:text-emerald-300",
  workshop:
    "border-amber-500 text-amber-700 dark:border-amber-400 dark:text-amber-300",
  preprint:
    "border-zinc-400 text-zinc-600 dark:border-zinc-500 dark:text-zinc-400",
};

const grouped: Record<Publication["type"], Publication[]> = {
  journal: [],
  conference: [],
  workshop: [],
  preprint: [],
};
for (const pub of publications) grouped[pub.type].push(pub);

const visibleGroups = typeOrder.filter((t) => grouped[t].length > 0);
---

<section id="publications" class="mx-auto max-w-3xl px-6 py-16">
  <h2
    class="text-2xl font-semibold tracking-tight text-zinc-900 md:text-3xl dark:text-zinc-100"
  >
    Publications
  </h2>

  <div class="mt-6 space-y-12">
    {
      visibleGroups.map((type) => (
        <div>
          <h3
            class={`flex items-baseline gap-2 border-l-4 pl-3 text-base font-bold uppercase tracking-wide ${typeHeadingClass[type]}`}
          >
            <span>{typeLabel[type]}</span>
            <span class="text-xs font-normal text-zinc-400 dark:text-zinc-500">
              · {grouped[type].length}
            </span>
          </h3>
          <ul class="mt-5 space-y-6">
            {grouped[type].map((pub) => (
              <li class="text-base leading-relaxed">
                <p class="text-zinc-700 dark:text-zinc-300">
                  {pub.authors.map((author, i) => {
                    const isSelf = SELF_NAMES.includes(author);
                    const showStar = pub.equalContribution && i < pub.equalContribution;
                    return (
                      <>
                        {isSelf ? (
                          <span class="font-semibold text-zinc-900 dark:text-zinc-100">
                            {author}{showStar && "*"}
                          </span>
                        ) : (
                          <span>{author}{showStar && "*"}</span>
                        )}
                        {i < pub.authors.length - 1 ? ", " : ""}
                      </>
                    );
                  })}
                  {pub.equalContribution && (
                    <span class="ml-1 text-sm text-zinc-500 dark:text-zinc-400">(* equal contribution)</span>
                  )}
                </p>
                <p class="mt-1 font-semibold text-zinc-900 dark:text-zinc-100">
                  {pub.title}
                </p>
                <p class="mt-1 italic text-zinc-500 dark:text-zinc-400">
                  {pub.venue}, {pub.year}
                </p>
                {pub.tags && pub.tags.length > 0 && (
                  <div class="mt-2 flex flex-wrap gap-1.5">
                    {pub.tags.map((tag) => (
                      <span class="inline-flex items-center rounded-full border border-zinc-200 bg-zinc-50 px-2 py-0.5 text-xs font-medium text-zinc-600 dark:border-zinc-700 dark:bg-zinc-800/50 dark:text-zinc-400">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                {pub.links &&
                  Object.values(pub.links).some((v) => Boolean(v)) && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {(pub.links.pdf || pub.links.arxiv) && (
                        <LinkChip
                          label="Paper"
                          href={pub.links.pdf ?? pub.links.arxiv!}
                        />
                      )}
                      {pub.links.code && (
                        <LinkChip label="Code" href={pub.links.code} />
                      )}
                      {pub.links.project && (
                        <LinkChip label="Project" href={pub.links.project} />
                      )}
                    </div>
                  )}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
